# Copy this to .streamlit/secrets.toml for Streamlit Cloud deployment.
# In the Streamlit Cloud dashboard, set these under Settings → Secrets.
#
# For KALSHI_PRIVATE_KEY_PEM: paste the full contents of your .pem/.txt key file.
# Streamlit Cloud supports multi-line secret values.

KALSHI_API_KEY = "your-key-id-here"
OPENROUTER_API_KEY = "sk-or-..."

KALSHI_PRIVATE_KEY_PEM = """
-----BEGIN PRIVATE KEY-----
paste your private key content here
-----END PRIVATE KEY-----
"""
